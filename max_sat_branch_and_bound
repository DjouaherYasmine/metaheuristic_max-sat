$O(b)$ par nœud. L'amélioration consiste à trier les variables **une seule fois**\navant la recherche selon leur nombre d'occurrences décroissant. Le papier (Fig. 5)\nmontre que ce tri réduit significativement le nombre de branches explorées.\n\n### Amélioration 3 : Borne inférieure améliorée (LB2)\nLe papier mentionne la technique LB2 utilisée par Alsinet et al. : à chaque nœud,\non calcule une borne inférieure plus serrée :\n\n$$LB2 = k + \\sum_{x \\text{ non assigné}} \\min(u(x), u(\\neg x))$$\n\nSi cette somme dépasse `min_false`, la branche est coupée immédiatement sans\ndescendre. C'est plus informatif que la simple condition $k \\geq \\text{min\\_false}$.","metadata":{}},{"id":"0eda89cb-dede-4c00-a935-787e9dfb74d5","cell_type":"code","source":"class MaxSATSolverImproved:\n    \"\"\"\n    Version améliorée de l'algorithme de Zhang et al.\n    Améliorations : PLD au pré-traitement, tri fixe des variables, borne LB2.\n    \"\"\"\n\n    def __init__(self, clauses, n_vars):\n        self.n = n_vars\n        self.initial_clauses = [frozenset(c) for c in clauses]\n        self.min_false = float('inf')\n        self.best_assignment = None\n        self.nodes_visited = 0\n\n    # ── Amélioration 1 : Pure Literal Deletion ──\n    def _pure_literal_deletion(self, clauses):\n        \"\"\"\n        Supprime itérativement les littéraux purs de la formule.\n        Un littéral x est pur si -x n'apparaît dans aucune clause.\n        \"\"\"\n        changed = True\n        assignment = {}\n        while changed:\n            changed = False\n            # Collecter tous les littéraux présents\n            literals = set()\n            for clause in clauses:\n                for lit in clause:\n                    literals.add(lit)\n            # Identifier les purs\n            pure = {lit for lit in literals if -lit not in literals}\n            if pure:\n                changed = True\n                for lit in pure:\n                    assignment[abs(lit)] = lit > 0\n                    clauses = [c for c in clauses if lit not in c]\n        return clauses, assignment\n\n    # ── Amélioration 2 : Tri fixe des variables ──\n    def _get_variable_order(self, clauses):\n        \"\"\"\n        Trie les variables par nombre d'occurrences décroissant — fait une seule fois.\n        \"\"\"\n        counts = {}\n        for clause in clauses:\n            for lit in clause:\n                v = abs(lit)\n                counts[v] = counts.get(v, 0) + 1\n        all_vars = list(range(1, self.n + 1))\n        return sorted(all_vars, key=lambda v: counts.get(v, 0), reverse=True)\n\n    def _apply_literal(self, clauses, literal):\n        new_clauses = []\n        false_count = 0\n        for clause in clauses:\n            if literal in clause:\n                continue\n            elif -literal in clause:\n                reduced = clause - {-literal}\n                if len(reduced) == 0:\n                    false_count += 1\n                else:\n                    new_clauses.append(reduced)\n            else:\n                new_clauses.append(clause)\n        return new_clauses, false_count\n\n    # ── Amélioration 3 : Borne LB2 ──\n    def _compute_lb2(self, clauses, k, assigned_vars):\n        \"\"\"\n        Borne inférieure améliorée : k + somme des min(u(x), u(-x))\n        pour chaque variable non assignée.\n        u(x) = nombre de clauses unitaires contenant x.\n        \"\"\"\n        u = {}\n        for clause in clauses:\n            if len(clause) == 1:\n                lit = next(iter(clause))\n                u[lit] = u.get(lit, 0) + 1\n\n        lb2 = k\n        for v in range(1, self.n + 1):\n            if v not in assigned_vars:\n                u_pos = u.get(v, 0)\n                u_neg = u.get(-v, 0)\n                lb2 += min(u_pos, u_neg)\n        return lb2\n\n    def _bb(self, clauses, k, assignment, assigned_vars, var_order):\n        self.nodes_visited += 1\n\n        if len(assigned_vars) == self.n:\n            total_false = k + len(clauses)\n            if total_false < self.min_false:\n                self.min_false = total_false\n                self.best_assignment = dict(assignment)\n            return\n\n        # Élagage standard\n        if k >= self.min_false:\n            return\n\n        # Amélioration 3 — élagage LB2\n        if self._compute_lb2(clauses, k, assigned_vars) >= self.min_false:\n            return\n\n        # Amélioration 2 — variable suivante selon l'ordre fixe\n        var = None\n        for v in var_order:\n            if v not in assigned_vars:\n                var = v\n                break\n\n        if var is None:\n            total_false = k + len(clauses)\n            if total_false < self.min_false:\n                self.min_false = total_false\n                self.best_assignment = dict(assignment)\n            return\n\n        assigned_vars = assigned_vars | {var}\n\n        # Branche True\n        if k < self.min_false:\n            new_clauses, added_false = self._apply_literal(clauses, var)\n            assignment[var] = True\n            self._bb(new_clauses, k + added_false, assignment, assigned_vars, var_order)\n\n        # Branche False\n        if k < self.min_false:\n            new_clauses, added_false = self._apply_literal(clauses, -var)\n            assignment[var] = False\n            self._bb(new_clauses, k + added_false, assignment, assigned_vars, var_order)\n\n        if var in assignment:\n            del assignment[var]\n\n    def solve(self):\n        self.min_false = float('inf')\n        self.best_assignment = None\n        self.nodes_visited = 0\n\n        # Amélioration 1 — PLD avant la recherche\n        clauses, pld_assignment = self._pure_literal_deletion(\n            list(self.initial_clauses)\n        )\n\n        # Amélioration 2 — tri fixe calculé une seule fois\n        var_order = self._get_variable_order(clauses)\n\n        assigned_vars = set(pld_assignment.keys())\n        assignment